# ApplyEase Configuration
# Copy this file to .env and replace with your actual credentials

# Snowflake Database Configuration (OAuth Authentication)
# Format: user@account.region.cloud_provider
SNOWFLAKE_USER=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_TOKEN=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=

# Google Gemini AI API Key
GEMINI_API_KEY=

# Google Sheets API Credentials
GOOGLE_SHEETS_CREDENTIALS_PATH=
GOOGLE_SHEETS_SPREADSHEET_ID=

# FastAPI Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_URL=http://localhost:8000

# Security
SECRET_KEY=generate_a_secure_random_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ML Model Settings
MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
FIELD_CLASSIFIER_MODEL_PATH=./backend/data/field_classifier.pkl
EMBEDDINGS_CACHE_PATH=./backend/data/embeddings_cache.pkl


# Chrome Extension ID (will be generated after loading unpacked extension)
EXTENSION_ID=
